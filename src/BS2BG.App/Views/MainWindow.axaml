<rxui:ReactiveWindow xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:rxui="using:ReactiveUI.Avalonia"
                     xmlns:vm="using:BS2BG.App.ViewModels"
                     x:Class="BS2BG.App.Views.MainWindow"
                     x:DataType="vm:MainWindowViewModel"
                     mc:Ignorable="d">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Grid Background="{DynamicResource BS2BGWindowBackgroundBrush}" />
</rxui:ReactiveWindow>
