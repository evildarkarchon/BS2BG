<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:automation="using:Avalonia.Automation"
        xmlns:input="using:Avalonia.Input"
        xmlns:services="using:BS2BG.App.Services"
        xmlns:vm="using:BS2BG.App.ViewModels"
        xmlns:workflow="using:BS2BG.App.ViewModels.Workflow"
        xmlns:diag="using:BS2BG.Core.Diagnostics"
        xmlns:models="using:BS2BG.Core.Models"
        xmlns:morphs="using:BS2BG.Core.Morphs"
        xmlns:sys="using:System"
        x:Class="BS2BG.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d">
  <Window.KeyBindings>
    <input:KeyBinding Gesture="Ctrl+N"
                      Command="{Binding NewProjectCommand}" />
    <input:KeyBinding Gesture="Ctrl+O"
                      Command="{Binding OpenProjectCommand}" />
    <input:KeyBinding Gesture="Ctrl+S"
                      Command="{Binding SaveProjectCommand}" />
    <input:KeyBinding Gesture="Ctrl+Alt+S"
                      Command="{Binding SaveProjectAsCommand}" />
    <input:KeyBinding Gesture="Ctrl+B"
                      Command="{Binding ExportBosJsonCommand}" />
    <input:KeyBinding Gesture="Ctrl+X"
                      Command="{Binding ExportBodyGenInisCommand}" />
    <input:KeyBinding Gesture="Ctrl+Z"
                      Command="{Binding UndoCommand}" />
    <input:KeyBinding Gesture="Ctrl+Y"
                      Command="{Binding RedoCommand}" />
    <input:KeyBinding Gesture="Ctrl+F"
                      Command="{Binding FocusGlobalSearchCommand}" />
    <input:KeyBinding Gesture="Ctrl+Shift+P"
                      Command="{Binding OpenCommandPaletteCommand}" />
  </Window.KeyBindings>

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.Resources>
    <services:NpcBulkScopeDisplayConverter x:Key="NpcBulkScopeDisplayConverter" />
    <services:AssignmentStrategyKindDisplayConverter x:Key="AssignmentStrategyKindDisplayConverter" />
  </Window.Resources>

  <Grid Background="{DynamicResource BS2BGWindowBackgroundBrush}"
        RowDefinitions="Auto,Auto,*">
    <Menu x:Name="MainMenuBar"
          automation:AutomationProperties.Name="Main menu"
          Grid.Row="0">
      <MenuItem Header="File">
        <MenuItem x:Name="NewProjectMenuItem"
                  Header="New"
                  automation:AutomationProperties.Name="New project"
                  automation:AutomationProperties.AcceleratorKey="Ctrl+N"
                  Command="{Binding NewProjectCommand}" />
        <MenuItem x:Name="OpenProjectMenuItem"
                  Header="Open..."
                  automation:AutomationProperties.Name="Open project"
                  automation:AutomationProperties.AcceleratorKey="Ctrl+O"
                  Command="{Binding OpenProjectCommand}" />
        <Separator />
        <MenuItem x:Name="SaveProjectMenuItem"
                  Header="Save"
                  automation:AutomationProperties.Name="Save project"
                  automation:AutomationProperties.AcceleratorKey="Ctrl+S"
                  Command="{Binding SaveProjectCommand}" />
        <MenuItem x:Name="SaveProjectAsMenuItem"
                  Header="Save As..."
                  automation:AutomationProperties.Name="Save project as"
                  automation:AutomationProperties.AcceleratorKey="Ctrl+Alt+S"
                  Command="{Binding SaveProjectAsCommand}" />
        <Separator />
        <MenuItem x:Name="ExportBosJsonMenuItem"
                  Header="Export Templates as BoS JSON"
                  automation:AutomationProperties.Name="Export templates as BoS JSON"
                  automation:AutomationProperties.AcceleratorKey="Ctrl+B"
                  Command="{Binding ExportBosJsonCommand}" />
        <MenuItem x:Name="ExportBodyGenInisMenuItem"
                  Header="Export BodyGen INIs"
                  automation:AutomationProperties.Name="Export BodyGen INIs"
                  automation:AutomationProperties.AcceleratorKey="Ctrl+X"
                  Command="{Binding ExportBodyGenInisCommand}" />
        <Separator />
        <MenuItem x:Name="CreatePortableBundleMenuItem"
                  Header="Create Portable Bundle"
                  automation:AutomationProperties.Name="Create Portable Bundle"
                  Command="{Binding CreatePortableBundleCommand}" />
      </MenuItem>
      <MenuItem Header="Edit">
        <MenuItem x:Name="UndoMenuItem"
                  Header="Undo"
                  automation:AutomationProperties.Name="Undo"
                  automation:AutomationProperties.AcceleratorKey="Ctrl+Z"
                  Command="{Binding UndoCommand}" />
        <MenuItem x:Name="RedoMenuItem"
                  Header="Redo"
                  automation:AutomationProperties.Name="Redo"
                  automation:AutomationProperties.AcceleratorKey="Ctrl+Y"
                  Command="{Binding RedoCommand}" />
        <Separator />
        <MenuItem Header="Command Palette..."
                  automation:AutomationProperties.Name="Open command palette"
                  automation:AutomationProperties.AcceleratorKey="Ctrl+Shift+P"
                  Command="{Binding OpenCommandPaletteCommand}" />
      </MenuItem>
      <MenuItem Header="Help">
        <MenuItem x:Name="AboutMenuItem"
                  Header="About Bodyslide to Bodygen"
                  automation:AutomationProperties.Name="About Bodyslide to Bodygen"
                  Command="{Binding ShowAboutCommand}" />
      </MenuItem>
    </Menu>

    <Border Grid.Row="1"
            Padding="16,12"
            Background="{DynamicResource BS2BGWindowBackgroundBrush}">
      <Grid ColumnDefinitions="Auto,260,Auto,Auto,*">
        <TextBlock DockPanel.Dock="Left"
                   Grid.Column="0"
                   Text="{Binding Title}"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,16,0"
                   VerticalAlignment="Center" />
        <TextBox x:Name="GlobalSearchBox"
                 Grid.Column="1"
                 TabIndex="0"
                 automation:AutomationProperties.Name="Search active view"
                 automation:AutomationProperties.AcceleratorKey="Ctrl+F"
                 Text="{Binding GlobalSearchText}"
                 PlaceholderText="Search active view" />
        <ComboBox x:Name="ThemePreferenceComboBox"
                  Grid.Column="2"
                  Width="108"
                  Margin="8,0,0,0"
                  TabIndex="1"
                  automation:AutomationProperties.Name="Theme preference"
                  ItemsSource="{Binding ThemePreferences}"
                  SelectedItem="{Binding SelectedThemePreference}" />
        <Button x:Name="OpenCommandPaletteButton"
                Grid.Column="3"
                Margin="8,0,0,0"
                Content="Commands"
                TabIndex="2"
                automation:AutomationProperties.Name="Open command palette"
                automation:AutomationProperties.AcceleratorKey="Ctrl+Shift+P"
                Command="{Binding OpenCommandPaletteCommand}" />
        <ProgressBar DockPanel.Dock="Right"
                     Grid.Column="4"
                     Width="160"
                     Height="4"
                     HorizontalAlignment="Right"
                     IsIndeterminate="True"
                     IsVisible="{Binding IsAnyBusy}" />
        <TextBlock x:Name="ShellStatusText"
                   Grid.Column="4"
                   Text="{Binding StatusMessage}"
                   Margin="16,0,176,0"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>

    <Popup x:Name="CommandPalettePopup"
           Grid.Row="1"
           PlacementTarget="{Binding #GlobalSearchBox}"
           Placement="Bottom"
           IsLightDismissEnabled="True"
           IsOpen="{Binding IsCommandPaletteOpen}">
      <Border Padding="8"
              Width="420"
              MaxHeight="360"
              Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
              BorderThickness="1">
        <Border.KeyBindings>
          <input:KeyBinding Gesture="Escape"
                            Command="{Binding CloseCommandPaletteCommand}" />
        </Border.KeyBindings>
        <Grid RowDefinitions="Auto,*">
          <TextBox x:Name="CommandPaletteSearchBox"
                   Grid.Row="0"
                   automation:AutomationProperties.Name="Run command search"
                   Text="{Binding CommandPaletteSearchText}"
                   PlaceholderText="Run command" />
          <ListBox x:Name="CommandPaletteListBox"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   automation:AutomationProperties.Name="Command palette results"
                   ItemsSource="{Binding VisibleCommandPaletteItems}"
                   SelectionChanged="OnCommandPaletteSelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="services:CommandDescriptor">
                <Grid ColumnDefinitions="*,Auto"
                      Margin="4">
                  <TextBlock Grid.Column="0" Text="{Binding Title}" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding GestureText}"
                             Opacity="0.72" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Popup>

    <TabControl x:Name="WorkspaceTabs"
                Grid.Row="2"
                Margin="12,0,12,12"
                SelectionChanged="OnWorkspaceSelectionChanged">
      <TabItem Header="Templates">
        <Grid x:Name="TemplatesDropZone"
              DragDrop.AllowDrop="True"
              DragDrop.DragOver="OnDragOver"
              DragDrop.Drop="OnDrop"
              ColumnDefinitions="280,4,*">
          <Border Grid.Column="0"
                  Padding="4,8,12,4">
            <Grid RowDefinitions="Auto,Auto,Auto,*">
              <StackPanel Grid.Row="0" Spacing="8">
                <Button x:Name="ImportPresetsButton"
                        Content="Add BodySlide XML Presets"
                        automation:AutomationProperties.Name="Add BodySlide XML presets"
                        Command="{Binding Templates.ImportPresetsCommand}" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Grid.Column="0"
                           x:Name="PresetNameInputBox"
                           automation:AutomationProperties.Name="Preset name"
                           Text="{Binding Templates.PresetNameInput}"
                           PlaceholderText="Preset name" />
                  <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="6"
                              Margin="8,0,0,0">
                    <Button x:Name="RenamePresetButton"
                            Content="Rename"
                            automation:AutomationProperties.Name="Rename selected preset"
                            Command="{Binding Templates.RenameSelectedPresetCommand}" />
                    <Button x:Name="DuplicatePresetButton"
                            Content="Duplicate"
                            automation:AutomationProperties.Name="Duplicate selected preset"
                            Command="{Binding Templates.DuplicateSelectedPresetCommand}" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,*">
                  <Button x:Name="RemovePresetButton"
                          Grid.Column="0"
                          Content="Remove"
                          automation:AutomationProperties.Name="Remove selected preset"
                          Command="{Binding Templates.RemoveSelectedPresetCommand}" />
                  <Button x:Name="ClearPresetsButton"
                          Grid.Column="1"
                          Margin="8,0,0,0"
                          Content="Clear"
                          automation:AutomationProperties.Name="Clear presets"
                          Command="{Binding Templates.ClearPresetsCommand}" />
                </Grid>
                <TextBlock Text="{Binding Templates.ValidationMessage}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
              </StackPanel>

              <Separator Grid.Row="1" Margin="0,12" />

              <ListBox x:Name="PresetListBox"
                       Grid.Row="2"
                       Focusable="True"
                       automation:AutomationProperties.Name="Template presets"
                       ItemsSource="{Binding Templates.VisiblePresets}"
                       SelectedItem="{Binding Templates.SelectedPreset}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:SliderPreset">
                    <TextBlock Text="{Binding Name}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>

          <GridSplitter Grid.Column="1"
                        ResizeDirection="Columns" />

          <Border Grid.Column="2"
                  Padding="12,8,4,4">
            <Grid ColumnDefinitions="*,4,320">
              <Grid Grid.Column="0"
                    RowDefinitions="Auto,Auto,*,Auto,*">
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,180,Auto,Auto,Auto,*"
                      RowDefinitions="Auto"
                      Margin="0,0,0,8">
                  <TextBlock Grid.Column="0"
                             Text="Profile"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0" />
                  <ComboBox x:Name="TemplateProfileComboBox"
                            Grid.Column="1"
                            automation:AutomationProperties.Name="Template profile"
                            ItemsSource="{Binding Templates.ProfileNames}"
                            SelectedItem="{Binding Templates.SelectedProfileName}" />
                  <CheckBox Grid.Column="2"
                            Margin="16,0,0,0"
                            Content="Omit Redundant Sliders"
                            automation:AutomationProperties.Name="Omit redundant sliders"
                            IsChecked="{Binding Templates.OmitRedundantSliders}" />
                  <Button x:Name="ManageProfilesButton"
                           Grid.Column="3"
                           Margin="16,0,0,0"
                           Content="Manage Profiles"
                           automation:AutomationProperties.Name="Manage Profiles"
                           Command="{Binding Templates.ManageProfilesCommand}" />
                  <Button x:Name="GenerateTemplatesButton"
                           Grid.Column="4"
                           Margin="8,0,0,0"
                           Content="Generate Templates"
                           automation:AutomationProperties.Name="Generate templates"
                           Command="{Binding Templates.GenerateTemplatesCommand}" />
                  <Button x:Name="CopyGeneratedTemplatesButton"
                          Grid.Column="5"
                          Margin="8,0,0,0"
                          HorizontalAlignment="Right"
                          Content="Copy"
                          automation:AutomationProperties.Name="Copy generated templates"
                          Command="{Binding Templates.CopyGeneratedTemplatesCommand}" />
                </Grid>

                <Border x:Name="ProfileFallbackInformationPanel"
                        Grid.Row="1"
                        Padding="8"
                        Margin="0,0,0,8"
                        Background="{DynamicResource BS2BGInfoBackgroundBrush}"
                        BorderBrush="{DynamicResource BS2BGInfoBorderBrush}"
                        BorderThickness="1"
                        IsVisible="{Binding Templates.IsProfileFallbackInformationVisible}"
                        automation:AutomationProperties.Name="Profile fallback information">
                  <TextBlock Text="{Binding Templates.ProfileFallbackInformationText}"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource BS2BGInfoForegroundBrush}" />
                </Border>

                <TextBox Grid.Row="2"
                         x:Name="TemplatePreviewTextBox"
                         automation:AutomationProperties.Name="Template preview"
                         Text="{Binding Templates.PreviewTemplateText}"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="13" />

                <TextBlock Grid.Row="3"
                           Margin="0,10,0,8"
                           Text="{Binding Templates.StatusMessage}"
                           TextWrapping="Wrap" />

                <TextBox Grid.Row="4"
                         x:Name="GeneratedTemplatesTextBox"
                         automation:AutomationProperties.Name="Generated templates"
                         Text="{Binding Templates.GeneratedTemplateText}"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas"
                         FontSize="13" />
              </Grid>

              <GridSplitter Grid.Column="1"
                            ResizeDirection="Columns" />

              <TabControl Grid.Column="2"
                          Margin="12,0,0,0">
                <TabItem Header="SetSliders">
                  <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnDefinitions="Auto,*,*,*"
                          Margin="0,0,0,8">
                      <TextBlock Grid.Row="0"
                                 Grid.Column="0"
                                 Text="All"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,6" />
                      <Button Grid.Row="0"
                              Grid.Column="1"
                              Content="0"
                              automation:AutomationProperties.Name="Set all slider percentages to 0"
                              Command="{Binding Templates.SetAllSliderPercentsTo0Command}"
                              Margin="0,0,6,6" />
                      <Button Grid.Row="0"
                              Grid.Column="2"
                              Content="50"
                              automation:AutomationProperties.Name="Set all slider percentages to 50"
                              Command="{Binding Templates.SetAllSliderPercentsTo50Command}"
                              Margin="0,0,6,6" />
                      <Button Grid.Row="0"
                              Grid.Column="3"
                              Content="100"
                              automation:AutomationProperties.Name="Set all slider percentages to 100"
                              Command="{Binding Templates.SetAllSliderPercentsTo100Command}"
                              Margin="0,0,0,6" />

                      <TextBlock Grid.Row="1"
                                 Grid.Column="0"
                                 Text="Min"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,6" />
                      <Button Grid.Row="1"
                              Grid.Column="1"
                              Content="0"
                              automation:AutomationProperties.Name="Set all minimum percentages to 0"
                              Command="{Binding Templates.SetAllMinPercentsTo0Command}"
                              Margin="0,0,6,6" />
                      <Button Grid.Row="1"
                              Grid.Column="2"
                              Content="50"
                              automation:AutomationProperties.Name="Set all minimum percentages to 50"
                              Command="{Binding Templates.SetAllMinPercentsTo50Command}"
                              Margin="0,0,6,6" />
                      <Button Grid.Row="1"
                              Grid.Column="3"
                              Content="100"
                              automation:AutomationProperties.Name="Set all minimum percentages to 100"
                              Command="{Binding Templates.SetAllMinPercentsTo100Command}"
                              Margin="0,0,0,6" />

                      <TextBlock Grid.Row="2"
                                 Grid.Column="0"
                                 Text="Max"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0" />
                      <Button Grid.Row="2"
                              Grid.Column="1"
                              Content="0"
                              automation:AutomationProperties.Name="Set all maximum percentages to 0"
                              Command="{Binding Templates.SetAllMaxPercentsTo0Command}"
                              Margin="0,0,6,0" />
                      <Button Grid.Row="2"
                              Grid.Column="2"
                              Content="50"
                              automation:AutomationProperties.Name="Set all maximum percentages to 50"
                              Command="{Binding Templates.SetAllMaxPercentsTo50Command}"
                              Margin="0,0,6,0" />
                      <Button Grid.Row="2"
                              Grid.Column="3"
                              Content="100"
                              automation:AutomationProperties.Name="Set all maximum percentages to 100"
                              Command="{Binding Templates.SetAllMaxPercentsTo100Command}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                      <ItemsControl x:Name="SetSliderInspectorRows"
                                    ItemsSource="{Binding Templates.SetSliderRows}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:SetSliderInspectorRowViewModel">
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,8">
                              <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                                <CheckBox Grid.Row="0"
                                          Content="{Binding Name}"
                                          IsChecked="{Binding Enabled}" />
                                <TextBox Grid.Row="1"
                                         Text="{Binding PreviewText}"
                                         IsReadOnly="True"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Margin="0,4,0,8" />
                                <Grid Grid.Row="2"
                                      ColumnDefinitions="Auto,*,Auto"
                                      Margin="0,0,0,6">
                                  <TextBlock Grid.Column="0"
                                             Text="Min"
                                             Width="32"
                                             VerticalAlignment="Center" />
                                  <Slider Grid.Column="1"
                                          Minimum="0"
                                          Maximum="100"
                                          Value="{Binding PercentMin}" />
                                  <TextBlock Grid.Column="2"
                                             Text="{Binding PercentMinText}"
                                             Width="44"
                                             TextAlignment="Right"
                                             VerticalAlignment="Center" />
                                </Grid>
                                <Grid Grid.Row="3"
                                      ColumnDefinitions="Auto,*,Auto">
                                  <TextBlock Grid.Column="0"
                                             Text="Max"
                                             Width="32"
                                             VerticalAlignment="Center" />
                                  <Slider Grid.Column="1"
                                          Minimum="0"
                                          Maximum="100"
                                          Value="{Binding PercentMax}" />
                                  <TextBlock Grid.Column="2"
                                             Text="{Binding PercentMaxText}"
                                             Width="44"
                                             TextAlignment="Right"
                                             VerticalAlignment="Center" />
                                </Grid>
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Grid>
                </TabItem>

                <TabItem Header="BoS JSON">
                  <Grid RowDefinitions="Auto,*">
                    <Button Grid.Row="0"
                            Content="Copy"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8"
                            automation:AutomationProperties.Name="Copy selected BoS JSON"
                            Command="{Binding Templates.CopySelectedBosJsonCommand}" />
                    <TextBox x:Name="BosJsonTextBox"
                             Grid.Row="1"
                             automation:AutomationProperties.Name="Selected BoS JSON"
                             Text="{Binding Templates.SelectedBosJsonText}"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="12" />
                  </Grid>
                </TabItem>
              </TabControl>
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Morphs">
        <Grid x:Name="NpcDropZone"
              DragDrop.AllowDrop="True"
              DragDrop.DragOver="OnDragOver"
              DragDrop.Drop="OnDrop"
              ColumnDefinitions="280,4,*,4,300"
              RowDefinitions="*,Auto,170">
          <Border Grid.Column="0"
                  Grid.RowSpan="3"
                  Padding="4,8,12,4">
            <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto,220">
              <TextBlock Grid.Row="0"
                         Text="Custom Targets"
                         FontWeight="SemiBold"
                         Margin="0,0,0,6" />
              <Grid Grid.Row="1"
                    ColumnDefinitions="*,Auto"
                    Margin="0,0,0,8">
                <TextBox Grid.Column="0"
                         x:Name="CustomTargetNameInputBox"
                         automation:AutomationProperties.Name="Custom target name"
                         Text="{Binding Morphs.TargetNameInput}"
                         PlaceholderText="Context|Gender|Race" />
                <Button x:Name="AddCustomTargetButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Add"
                        automation:AutomationProperties.Name="Add custom target"
                        Command="{Binding Morphs.AddCustomTargetCommand}" />
              </Grid>
              <ListBox x:Name="CustomTargetsListBox"
                       Grid.Row="2"
                       Focusable="True"
                       automation:AutomationProperties.Name="Custom targets"
                       ItemsSource="{Binding Morphs.CustomTargets}"
                       SelectedItem="{Binding Morphs.SelectedCustomTarget}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:CustomMorphTarget">
                    <TextBlock Text="{Binding Name}" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <Grid Grid.Row="3"
                    ColumnDefinitions="*,*"
                    Margin="0,8,0,12">
                <Button x:Name="RemoveCustomTargetButton"
                        Grid.Column="0"
                        Content="Remove"
                        automation:AutomationProperties.Name="Remove custom target"
                        Command="{Binding Morphs.RemoveCustomTargetCommand}" />
                <Button x:Name="ClearCustomTargetsButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Clear"
                        automation:AutomationProperties.Name="Clear custom targets"
                        Command="{Binding Morphs.ClearCustomTargetsCommand}" />
              </Grid>

              <TextBlock Grid.Row="4"
                         Text="{Binding Morphs.TargetNameValidationMessage}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />

              <Grid Grid.Row="5"
                    ColumnDefinitions="Auto,*,Auto"
                    Margin="0,12,0,8">
                <TextBlock Grid.Column="0"
                           Text="Imported NPCs"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Morphs.NpcDatabaseCountBadgeText}"
                           Margin="6,0,0,0"
                           VerticalAlignment="Center" />
                <Button x:Name="ImportNpcsButton"
                        Grid.Column="2"
                        Content="Import"
                        automation:AutomationProperties.Name="Import NPCs"
                        Command="{Binding Morphs.ImportNpcsCommand}" />
              </Grid>

              <Grid Grid.Row="6"
                    RowDefinitions="Auto,*,Auto">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      Margin="0,0,0,8">
                  <TextBox Grid.Column="0"
                           x:Name="ImportedNpcSearchBox"
                           automation:AutomationProperties.Name="Search imported NPCs"
                           Text="{Binding Morphs.NpcDatabaseSearchText}"
                           PlaceholderText="Search imported NPCs" />
                  <CheckBox Grid.Column="1"
                            Margin="8,0,0,0"
                            Content="Assign Random"
                            automation:AutomationProperties.Name="Assign random presets on import"
                            IsChecked="{Binding Morphs.AssignRandomOnAdd}" />
                </Grid>
                <ListBox x:Name="ImportedNpcListBox"
                         Grid.Row="1"
                         Focusable="True"
                         automation:AutomationProperties.Name="Imported NPCs"
                         ItemsSource="{Binding Morphs.VisibleNpcDatabase}"
                         SelectedItem="{Binding Morphs.SelectedImportedNpc}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Npc">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Name}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Mod}"
                                   Margin="8,0,0,0"
                                   Opacity="0.72" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      Margin="0,8,0,0">
                  <Button x:Name="AddSelectedNpcButton"
                          Grid.Column="0"
                          Content="Add"
                          automation:AutomationProperties.Name="Add selected imported NPC"
                          Command="{Binding Morphs.AddSelectedNpcCommand}" />
                  <Button x:Name="AddAllImportedNpcsButton"
                          Grid.Column="1"
                          Margin="8,0,0,0"
                          Content="Add All"
                          automation:AutomationProperties.Name="Add all visible imported NPCs"
                          Command="{Binding Morphs.AddAllVisibleImportedNpcsCommand}" />
                </Grid>
              </Grid>
            </Grid>
          </Border>

          <GridSplitter Grid.Column="1"
                        Grid.RowSpan="3"
                        ResizeDirection="Columns" />

          <Border Grid.Column="2"
                  Grid.Row="0"
                  Padding="12,8,12,4">
            <Grid RowDefinitions="Auto,Auto,*">
              <Grid Grid.Row="0"
                    ColumnDefinitions="Auto,Auto,*,Auto,140,Auto,Auto,Auto,Auto,Auto,Auto"
                    Margin="0,0,0,8">
                <TextBlock Grid.Column="0"
                           Text="Individual NPCs"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Morphs.NpcCountBadgeText}"
                           Margin="6,0,12,0"
                           VerticalAlignment="Center" />
                <TextBox Grid.Column="2"
                          x:Name="NpcSearchBox"
                          automation:AutomationProperties.Name="Search NPCs"
                          Text="{Binding Morphs.SearchText}"
                          PlaceholderText="Search NPCs" />
                <TextBlock x:Name="NpcBulkScopeLabel"
                         Grid.Column="3"
                         Margin="8,0,0,0"
                         Text="Scope"
                         VerticalAlignment="Center" />
                <ComboBox x:Name="NpcBulkScopeComboBox"
                          Grid.Column="4"
                          Margin="8,0,0,0"
                          automation:AutomationProperties.Name="Scope"
                          ItemsSource="{Binding Morphs.NpcBulkScopes}"
                          SelectedItem="{Binding Morphs.SelectedNpcBulkScope}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="workflow:NpcBulkScope">
                      <TextBlock Text="{Binding ., Converter={StaticResource NpcBulkScopeDisplayConverter}}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Button x:Name="FillEmptyNpcsButton"
                        Grid.Column="5"
                        Margin="8,0,0,0"
                        Content="Fill Visible Empty"
                        automation:AutomationProperties.Name="Fill Visible Empty"
                        Command="{Binding Morphs.FillEmptyNpcsCommand}" />
                <Button x:Name="ClearNpcAssignmentsButton"
                        Grid.Column="6"
                        Margin="8,0,0,0"
                        Content="Clear Assignments"
                        automation:AutomationProperties.Name="Clear visible NPC assignments"
                        Command="{Binding Morphs.ClearAssignmentsCommand}" />
                <Button x:Name="RemoveNpcButton"
                        Grid.Column="7"
                        Margin="8,0,0,0"
                        Content="Remove NPC"
                        automation:AutomationProperties.Name="Remove selected NPC"
                        Command="{Binding Morphs.RemoveSelectedNpcCommand}" />
                <Button x:Name="ClearVisibleNpcsButton"
                        Grid.Column="8"
                        Margin="8,0,0,0"
                        Content="Clear"
                        automation:AutomationProperties.Name="Clear scoped NPCs"
                        Command="{Binding Morphs.ClearVisibleNpcsCommand}" />
                <Button x:Name="SelectedNpcAssignButton"
                        Grid.Column="9"
                        Margin="8,0,0,0"
                        Content="Assign Selected"
                        automation:AutomationProperties.Name="Assign preset to selected NPCs"
                        Command="{Binding Morphs.AssignSelectedNpcsCommand}" />
                <Button x:Name="SelectedNpcClearAssignmentsButton"
                        Grid.Column="10"
                        Margin="8,0,0,0"
                        Content="Clear Selected"
                        automation:AutomationProperties.Name="Clear selected NPC assignments"
                        Command="{Binding Morphs.ClearSelectedNpcAssignmentsCommand}" />
              </Grid>

              <Grid Grid.Row="1"
                    ColumnDefinitions="*,*,*,*,*,*,1.2*"
                    Margin="8,0,8,4">
                <Button x:Name="NpcNameFilterButton"
                        Grid.Column="0"
                        Padding="0"
                        HorizontalAlignment="Left"
                        automation:AutomationProperties.Name="Filter NPCs by name"
                        Command="{Binding Morphs.ToggleNpcNameFilterCommand}">
                  <StackPanel>
                    <TextBlock Text="Name" />
                    <TextBlock x:Name="NpcNameFilterBadge" Text="{Binding Morphs.NpcNameFilterBadgeText}" Foreground="{DynamicResource BS2BGActiveFilterForegroundBrush}" FontSize="12" />
                  </StackPanel>
                </Button>
                <Popup x:Name="NpcNameFilterPopup"
                       Grid.Column="0"
                       PlacementTarget="{Binding #NpcNameFilterButton}"
                       Placement="Bottom"
                       IsLightDismissEnabled="True"
                       IsOpen="{Binding Morphs.IsNpcNameFilterOpen, Mode=TwoWay}">
                  <Border Padding="8" Width="240" MaxHeight="280" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBox x:Name="NpcNameFilterSearchBox" Grid.Row="0" automation:AutomationProperties.Name="Search NPC names" Text="{Binding Morphs.NpcNameColumnSearchText, Mode=TwoWay}" PlaceholderText="Search names" />
                      <ListBox x:Name="NpcNameFilterValuesListBox" Grid.Row="1" Margin="0,8,0,8" Height="160" SelectionMode="Multiple" automation:AutomationProperties.Name="NPC name filter values" ItemsSource="{Binding Morphs.NpcNameColumnValues}" SelectionChanged="OnNpcNameFilterSelectionChanged" />
                      <Button x:Name="NpcNameFilterClearButton" Grid.Row="2" HorizontalAlignment="Right" Content="Clear" automation:AutomationProperties.Name="Clear NPC name filter" Click="OnNpcNameFilterClearClick" />
                    </Grid>
                  </Border>
                </Popup>
                <Button x:Name="NpcModFilterButton"
                        Grid.Column="1"
                        Padding="0"
                        HorizontalAlignment="Left"
                        automation:AutomationProperties.Name="Filter NPCs by mod"
                        Command="{Binding Morphs.ToggleNpcModFilterCommand}">
                  <StackPanel>
                    <TextBlock Text="Master" />
                    <TextBlock x:Name="NpcModFilterBadge" Text="{Binding Morphs.NpcModFilterBadgeText}" Foreground="{DynamicResource BS2BGActiveFilterForegroundBrush}" FontSize="12" />
                  </StackPanel>
                </Button>
                <Popup x:Name="NpcModFilterPopup" Grid.Column="1" PlacementTarget="{Binding #NpcModFilterButton}" Placement="Bottom" IsLightDismissEnabled="True" IsOpen="{Binding Morphs.IsNpcModFilterOpen, Mode=TwoWay}">
                  <Border Padding="8" Width="240" MaxHeight="280" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBox x:Name="NpcModFilterSearchBox" Grid.Row="0" automation:AutomationProperties.Name="Search NPC mods" Text="{Binding Morphs.NpcModColumnSearchText, Mode=TwoWay}" PlaceholderText="Search mods" />
                      <ListBox x:Name="NpcModFilterValuesListBox" Grid.Row="1" Margin="0,8,0,8" Height="160" SelectionMode="Multiple" automation:AutomationProperties.Name="NPC mod filter values" ItemsSource="{Binding Morphs.NpcModColumnValues}" SelectionChanged="OnNpcModFilterSelectionChanged" />
                      <Button x:Name="NpcModFilterClearButton" Grid.Row="2" HorizontalAlignment="Right" Content="Clear" automation:AutomationProperties.Name="Clear NPC mod filter" Click="OnNpcModFilterClearClick" />
                    </Grid>
                  </Border>
                </Popup>
                <Button x:Name="NpcRaceFilterButton"
                        Grid.Column="2"
                        Padding="0"
                        HorizontalAlignment="Left"
                        automation:AutomationProperties.Name="Filter NPCs by race"
                        Command="{Binding Morphs.ToggleNpcRaceFilterCommand}">
                  <StackPanel>
                    <TextBlock Text="Race" />
                    <TextBlock x:Name="NpcRaceFilterButtonBadge" Text="{Binding Morphs.NpcRaceFilterBadgeText}" Foreground="{DynamicResource BS2BGActiveFilterForegroundBrush}" FontSize="12" />
                  </StackPanel>
                </Button>
                <Popup x:Name="NpcRaceFilterPopup"
                       Grid.Column="2"
                       PlacementTarget="{Binding #NpcRaceFilterButton}"
                       Placement="Bottom"
                       IsLightDismissEnabled="True"
                       IsOpen="{Binding Morphs.IsNpcRaceFilterOpen, Mode=TwoWay}">
                  <Border Padding="8"
                          Width="240"
                          MaxHeight="280"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="1">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBox x:Name="NpcRaceFilterSearchBox"
                               Grid.Row="0"
                               automation:AutomationProperties.Name="Search NPC races"
                               Text="{Binding Morphs.NpcRaceColumnSearchText, Mode=TwoWay}"
                               PlaceholderText="Search races" />
                      <ListBox x:Name="NpcRaceFilterValuesListBox"
                               Grid.Row="1"
                               Margin="0,8,0,8"
                               Height="160"
                               SelectionMode="Multiple"
                               automation:AutomationProperties.Name="NPC race filter values"
                               ItemsSource="{Binding Morphs.NpcRaceColumnValues}"
                               SelectionChanged="OnNpcRaceFilterSelectionChanged" />
                      <Button x:Name="NpcRaceFilterClearButton"
                              Grid.Row="2"
                              HorizontalAlignment="Right"
                              Content="Clear"
                              automation:AutomationProperties.Name="Clear NPC race filter"
                              Click="OnNpcRaceFilterClearClick" />
                    </Grid>
                  </Border>
                </Popup>
                <TextBlock x:Name="NpcRaceFilterBadge"
                           Grid.Column="2"
                           Margin="0,20,0,0"
                           Text="{Binding Morphs.NpcRaceFilterBadgeText}"
                           Foreground="{DynamicResource BS2BGActiveFilterForegroundBrush}"
                           FontSize="12" />
                <Button x:Name="NpcEditorIdFilterButton" Grid.Column="3" Padding="0" HorizontalAlignment="Left" automation:AutomationProperties.Name="Filter NPCs by editor ID" Command="{Binding Morphs.ToggleNpcEditorIdFilterCommand}">
                  <StackPanel><TextBlock Text="EditorID" /><TextBlock x:Name="NpcEditorIdFilterBadge" Text="{Binding Morphs.NpcEditorIdFilterBadgeText}" Foreground="{DynamicResource BS2BGActiveFilterForegroundBrush}" FontSize="12" /></StackPanel>
                </Button>
                <Popup x:Name="NpcEditorIdFilterPopup" Grid.Column="3" PlacementTarget="{Binding #NpcEditorIdFilterButton}" Placement="Bottom" IsLightDismissEnabled="True" IsOpen="{Binding Morphs.IsNpcEditorIdFilterOpen, Mode=TwoWay}">
                  <Border Padding="8" Width="240" MaxHeight="280" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBox x:Name="NpcEditorIdFilterSearchBox" Grid.Row="0" automation:AutomationProperties.Name="Search NPC editor IDs" Text="{Binding Morphs.NpcEditorIdColumnSearchText, Mode=TwoWay}" PlaceholderText="Search editor IDs" />
                      <ListBox x:Name="NpcEditorIdFilterValuesListBox" Grid.Row="1" Margin="0,8,0,8" Height="160" SelectionMode="Multiple" automation:AutomationProperties.Name="NPC editor ID filter values" ItemsSource="{Binding Morphs.NpcEditorIdColumnValues}" SelectionChanged="OnNpcEditorIdFilterSelectionChanged" />
                      <Button x:Name="NpcEditorIdFilterClearButton" Grid.Row="2" HorizontalAlignment="Right" Content="Clear" automation:AutomationProperties.Name="Clear NPC editor ID filter" Click="OnNpcEditorIdFilterClearClick" />
                    </Grid>
                  </Border>
                </Popup>
                <Button x:Name="NpcFormIdFilterButton" Grid.Column="4" Padding="0" HorizontalAlignment="Left" automation:AutomationProperties.Name="Filter NPCs by form ID" Command="{Binding Morphs.ToggleNpcFormIdFilterCommand}">
                  <StackPanel><TextBlock Text="FormID" /><TextBlock x:Name="NpcFormIdFilterBadge" Text="{Binding Morphs.NpcFormIdFilterBadgeText}" Foreground="{DynamicResource BS2BGActiveFilterForegroundBrush}" FontSize="12" /></StackPanel>
                </Button>
                <Popup x:Name="NpcFormIdFilterPopup" Grid.Column="4" PlacementTarget="{Binding #NpcFormIdFilterButton}" Placement="Bottom" IsLightDismissEnabled="True" IsOpen="{Binding Morphs.IsNpcFormIdFilterOpen, Mode=TwoWay}">
                  <Border Padding="8" Width="240" MaxHeight="280" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBox x:Name="NpcFormIdFilterSearchBox" Grid.Row="0" automation:AutomationProperties.Name="Search NPC form IDs" Text="{Binding Morphs.NpcFormIdColumnSearchText, Mode=TwoWay}" PlaceholderText="Search form IDs" />
                      <ListBox x:Name="NpcFormIdFilterValuesListBox" Grid.Row="1" Margin="0,8,0,8" Height="160" SelectionMode="Multiple" automation:AutomationProperties.Name="NPC form ID filter values" ItemsSource="{Binding Morphs.NpcFormIdColumnValues}" SelectionChanged="OnNpcFormIdFilterSelectionChanged" />
                      <Button x:Name="NpcFormIdFilterClearButton" Grid.Row="2" HorizontalAlignment="Right" Content="Clear" automation:AutomationProperties.Name="Clear NPC form ID filter" Click="OnNpcFormIdFilterClearClick" />
                    </Grid>
                  </Border>
                </Popup>
                <Button x:Name="NpcAssignmentStateFilterButton" Grid.Column="5" Padding="0" HorizontalAlignment="Left" automation:AutomationProperties.Name="Filter NPCs by assignment state" Command="{Binding Morphs.ToggleNpcAssignmentStateFilterCommand}">
                  <StackPanel><TextBlock Text="Assignment" /><TextBlock x:Name="NpcAssignmentStateFilterBadge" Text="{Binding Morphs.NpcAssignmentStateFilterBadgeText}" Foreground="{DynamicResource BS2BGActiveFilterForegroundBrush}" FontSize="12" /></StackPanel>
                </Button>
                <Popup x:Name="NpcAssignmentStateFilterPopup" Grid.Column="5" PlacementTarget="{Binding #NpcAssignmentStateFilterButton}" Placement="Bottom" IsLightDismissEnabled="True" IsOpen="{Binding Morphs.IsNpcAssignmentStateFilterOpen, Mode=TwoWay}">
                  <Border Padding="8" Width="240" MaxHeight="280" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBox x:Name="NpcAssignmentStateFilterSearchBox" Grid.Row="0" automation:AutomationProperties.Name="Search NPC assignment states" Text="{Binding Morphs.NpcAssignmentStateColumnSearchText, Mode=TwoWay}" PlaceholderText="Search assignment states" />
                      <ListBox x:Name="NpcAssignmentStateFilterValuesListBox" Grid.Row="1" Margin="0,8,0,8" Height="160" SelectionMode="Multiple" automation:AutomationProperties.Name="NPC assignment state filter values" ItemsSource="{Binding Morphs.NpcAssignmentStateColumnValues}" SelectionChanged="OnNpcAssignmentStateFilterSelectionChanged" />
                      <Button x:Name="NpcAssignmentStateFilterClearButton" Grid.Row="2" HorizontalAlignment="Right" Content="Clear" automation:AutomationProperties.Name="Clear NPC assignment state filter" Click="OnNpcAssignmentStateFilterClearClick" />
                    </Grid>
                  </Border>
                </Popup>
                <Button x:Name="NpcPresetFilterButton" Grid.Column="6" Padding="0" HorizontalAlignment="Left" automation:AutomationProperties.Name="Filter NPCs by presets" Command="{Binding Morphs.ToggleNpcPresetFilterCommand}">
                  <StackPanel><TextBlock Text="Slider Presets" /><TextBlock x:Name="NpcPresetFilterBadge" Text="{Binding Morphs.NpcPresetFilterBadgeText}" Foreground="{DynamicResource BS2BGActiveFilterForegroundBrush}" FontSize="12" /></StackPanel>
                </Button>
                <Popup x:Name="NpcPresetFilterPopup" Grid.Column="6" PlacementTarget="{Binding #NpcPresetFilterButton}" Placement="Bottom" IsLightDismissEnabled="True" IsOpen="{Binding Morphs.IsNpcPresetFilterOpen, Mode=TwoWay}">
                  <Border Padding="8" Width="240" MaxHeight="280" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBox x:Name="NpcPresetFilterSearchBox" Grid.Row="0" automation:AutomationProperties.Name="Search NPC presets" Text="{Binding Morphs.NpcPresetColumnSearchText, Mode=TwoWay}" PlaceholderText="Search presets" />
                      <ListBox x:Name="NpcPresetFilterValuesListBox" Grid.Row="1" Margin="0,8,0,8" Height="160" SelectionMode="Multiple" automation:AutomationProperties.Name="NPC preset filter values" ItemsSource="{Binding Morphs.NpcPresetColumnValues}" SelectionChanged="OnNpcPresetFilterSelectionChanged" />
                      <Button x:Name="NpcPresetFilterClearButton" Grid.Row="2" HorizontalAlignment="Right" Content="Clear" automation:AutomationProperties.Name="Clear NPC preset filter" Click="OnNpcPresetFilterClearClick" />
                    </Grid>
                  </Border>
                </Popup>
              </Grid>

              <Border Grid.Row="2"
                      Padding="8"
                      Margin="0,0,0,8"
                      Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                      BorderThickness="1"
                      automation:AutomationProperties.Name="Assignment strategy editor">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*"
                      ColumnDefinitions="Auto,180,Auto,120,Auto,Auto,Auto">
                  <TextBlock Grid.Row="0"
                             Grid.Column="0"
                             Grid.ColumnSpan="7"
                             Text="Strategy"
                             FontWeight="SemiBold"
                             Margin="0,0,0,8" />
                  <ComboBox x:Name="AssignmentStrategyKindComboBox"
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            automation:AutomationProperties.Name="Assignment strategy type"
                            ItemsSource="{Binding Morphs.StrategyKinds}"
                            SelectedItem="{Binding Morphs.SelectedAssignmentStrategyKind}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="morphs:AssignmentStrategyKind">
                        <TextBlock Text="{Binding ., Converter={StaticResource AssignmentStrategyKindDisplayConverter}}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Grid.Row="1"
                             Grid.Column="2"
                             Text="Seed"
                             VerticalAlignment="Center"
                             Margin="16,0,8,0" />
                  <TextBox x:Name="AssignmentStrategySeedTextBox"
                           Grid.Row="1"
                           Grid.Column="3"
                           automation:AutomationProperties.Name="Seed"
                           Text="{Binding Morphs.StrategySeedText}"
                           PlaceholderText="Seed" />
                  <Button x:Name="SaveStrategyButton"
                          Grid.Row="1"
                          Grid.Column="4"
                          Margin="16,0,0,0"
                          Content="Save Strategy"
                          automation:AutomationProperties.Name="Save Strategy"
                          Command="{Binding Morphs.SaveStrategyConfigurationCommand}" />
                  <Button x:Name="ApplyStrategyButton"
                          Grid.Row="1"
                          Grid.Column="5"
                          Margin="8,0,0,0"
                          Content="Apply Strategy"
                          automation:AutomationProperties.Name="Apply Strategy"
                          Command="{Binding Morphs.ApplyStrategyCommand}" />
                  <Button x:Name="AddStrategyRuleButton"
                          Grid.Row="1"
                          Grid.Column="6"
                          Margin="8,0,0,0"
                          Content="Add Rule"
                          automation:AutomationProperties.Name="Add Strategy Rule"
                          Command="{Binding Morphs.AddStrategyRuleCommand}" />
                  <TextBlock Grid.Row="2"
                             Grid.Column="0"
                             Grid.ColumnSpan="7"
                             Text="Available strategies: Seeded random, Round-robin, Weighted, Race filters, Groups / buckets. Same project, strategy, eligible rows, and seed produce the same assignments. Saved in project; reproducible in CLI and bundles. Apply Strategy affects all NPC rows in the project for deterministic replay."
                             TextWrapping="Wrap"
                             Margin="0,8,0,0" />
                  <TextBlock Grid.Row="3"
                             Grid.Column="0"
                             Grid.ColumnSpan="7"
                             Text="Matches imported NPC Race text only; no game-data lookup. Use comma-separated preset/race tokens; PresetNames and RaceFilters trim spaces and remove duplicates. No eligible preset after strategy rules is shown as text."
                             TextWrapping="Wrap"
                             Opacity="0.72"
                             Margin="0,4,0,0" />
                  <TextBlock Grid.Row="4"
                             Grid.Column="0"
                             Grid.ColumnSpan="7"
                             Text="{Binding Morphs.StrategySummaryText}"
                             TextWrapping="Wrap"
                             Margin="0,4,0,0" />
                  <StackPanel Grid.Row="5"
                              Grid.Column="0"
                              Grid.ColumnSpan="7"
                              Spacing="6"
                              Margin="0,8,0,0">
                    <TextBlock Text="{Binding Morphs.InvalidLoadedStrategyMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                    <TextBlock Text="{Binding Morphs.StrategyValidationMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" />
                    <ItemsControl x:Name="AssignmentStrategyRuleRows"
                                  ItemsSource="{Binding Morphs.StrategyRules}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:AssignmentStrategyRuleRowViewModel">
                          <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                  BorderThickness="0,1,0,0"
                                  Padding="0,6,0,0"
                                  Margin="0,2,0,0">
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="120,*,*,100,140">
                              <TextBox Grid.Row="0"
                                       Grid.Column="0"
                                       Margin="0,0,8,0"
                                       automation:AutomationProperties.Name="Strategy rule name"
                                       Text="{Binding Name}"
                                       PlaceholderText="Rule name" />
                              <TextBox Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="0,0,8,0"
                                       automation:AutomationProperties.Name="PresetNames comma-separated tokens"
                                       Text="{Binding PresetNamesText}"
                                       PlaceholderText="PresetNames" />
                              <TextBox Grid.Row="0"
                                       Grid.Column="2"
                                       Margin="0,0,8,0"
                                       automation:AutomationProperties.Name="RaceFilters comma-separated tokens"
                                       Text="{Binding RaceFiltersText}"
                                       PlaceholderText="RaceFilters" />
                              <NumericUpDown Grid.Row="0"
                                             Grid.Column="3"
                                             Margin="0,0,8,0"
                                             Minimum="0"
                                             Maximum="1000"
                                             automation:AutomationProperties.Name="Weight"
                                             Value="{Binding Weight}" />
                              <TextBox Grid.Row="0"
                                       Grid.Column="4"
                                       automation:AutomationProperties.Name="BucketName"
                                       Text="{Binding BucketName}"
                                       PlaceholderText="BucketName" />
                              <TextBlock Grid.Row="1"
                                         Grid.Column="0"
                                         Grid.ColumnSpan="5"
                                         Text="{Binding ValidationMessage}"
                                         TextWrapping="Wrap"
                                         Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                                         Margin="0,4,0,0" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Grid>
              </Border>

              <Grid Grid.Row="3">
                <ListBox x:Name="NpcListBox"
                         SelectionMode="Multiple"
                         Focusable="True"
                         automation:AutomationProperties.Name="Individual NPCs"
                         SelectionChanged="OnNpcSelectionChanged"
                         ItemsSource="{Binding Morphs.VisibleNpcs}"
                         SelectedItem="{Binding Morphs.SelectedNpc}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Npc">
                      <Grid ColumnDefinitions="*,*,*,*,*,*,1.2*">
                        <TextBlock Grid.Column="0" Text="{Binding Name}" />
                        <TextBlock Grid.Column="1" Text="{Binding Mod}" />
                        <TextBlock Grid.Column="2" Text="{Binding Race}" />
                        <TextBlock Grid.Column="3" Text="{Binding EditorId}" />
                        <TextBlock Grid.Column="4" Text="{Binding FormId}" />
                        <TextBlock Grid.Column="5" Text="{Binding HasPresets}" />
                        <TextBlock Grid.Column="6" Text="{Binding SliderPresetsText}" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Border x:Name="NpcFilteredEmptyState"
                        Padding="16"
                        Margin="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource BS2BGInfoBackgroundBrush}"
                        BorderBrush="{DynamicResource BS2BGInfoBorderBrush}"
                        BorderThickness="1"
                        IsVisible="{Binding Morphs.IsNpcFilteredEmptyVisible}"
                        automation:AutomationProperties.Name="NPC filtered empty state">
                  <StackPanel Spacing="8" MaxWidth="420">
                    <TextBlock x:Name="NpcFilteredEmptyHeading"
                               Text="No NPCs match the current filters"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BS2BGInfoForegroundBrush}"
                               TextAlignment="Center" />
                    <TextBlock x:Name="NpcFilteredEmptyBody"
                               Text="Clear one or more filters to show hidden NPCs, or change the bulk scope before running an action."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource BS2BGInfoForegroundBrush}"
                               TextAlignment="Center" />
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </Border>

          <GridSplitter Grid.Column="3"
                        Grid.RowSpan="3"
                        ResizeDirection="Columns" />

          <Border Grid.Column="4"
                  Grid.RowSpan="3"
                  Padding="12,8,4,4">
            <Grid RowDefinitions="Auto,*,Auto,*,Auto">
              <Grid Grid.Row="0"
                    ColumnDefinitions="*,Auto,Auto"
                    Margin="0,0,0,8">
                <TextBlock Grid.Column="0"
                           Text="{Binding Morphs.SelectedTargetName}"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Morphs.TargetPresetCountText}"
                           VerticalAlignment="Center" />
                <Button x:Name="ViewImageButton"
                        Grid.Column="2"
                        Content="View Image"
                        Margin="8,0,0,0"
                        automation:AutomationProperties.Name="View selected NPC image"
                        Command="{Binding Morphs.ViewSelectedNpcImageCommand}" />
              </Grid>

              <Border x:Name="TargetPresetWarningBanner"
                      Grid.Row="0"
                      Margin="0,28,0,8"
                      Padding="8"
                      Background="{DynamicResource BS2BGWarningBackgroundBrush}"
                      BorderBrush="{DynamicResource BS2BGWarningBorderBrush}"
                      BorderThickness="1"
                      IsVisible="{Binding Morphs.IsTargetPresetWarningVisible}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding Morphs.TargetPresetWarningText}"
                             Foreground="{DynamicResource BS2BGWarningForegroundBrush}" />
                  <Button x:Name="TargetPresetWarningTrimButton"
                          Content="Trim to 76"
                          automation:AutomationProperties.Name="Trim selected target to 76 presets"
                          Command="{Binding Morphs.TrimSelectedTargetTo76Command}"
                          IsVisible="{Binding Morphs.IsTargetPresetTrimVisible}" />
                </StackPanel>
              </Border>

              <Grid Grid.Row="1"
                    RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Available Presets"
                           Margin="0,0,0,6" />
                <ListBox Grid.Row="1"
                         x:Name="AvailablePresetsListBox"
                         Focusable="True"
                         automation:AutomationProperties.Name="Available presets"
                         ItemsSource="{Binding Morphs.Presets}"
                         SelectedItem="{Binding Morphs.SelectedAvailablePreset}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:SliderPreset">
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Grid Grid.Row="2"
                    ColumnDefinitions="*,*"
                    Margin="0,8,0,8">
                <Button x:Name="AddSelectedPresetToTargetButton"
                        Grid.Column="0"
                        Content="Add"
                        automation:AutomationProperties.Name="Add selected preset to target"
                        Command="{Binding Morphs.AddSelectedPresetToTargetCommand}" />
                <Button x:Name="AddAllPresetsToTargetButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Add All"
                        automation:AutomationProperties.Name="Add all presets to target"
                        Command="{Binding Morphs.AddAllPresetsToTargetCommand}" />
              </Grid>

              <Grid Grid.Row="3"
                    RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Assigned Presets"
                           Margin="0,0,0,6" />
                <ListBox Grid.Row="1"
                         x:Name="AssignedPresetsListBox"
                         Focusable="True"
                         automation:AutomationProperties.Name="Assigned presets"
                         ItemsSource="{Binding Morphs.SelectedTargetPresets}"
                         SelectedItem="{Binding Morphs.SelectedAssignedPreset}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:SliderPreset">
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>

              <Grid Grid.Row="4"
                    ColumnDefinitions="*,*"
                    Margin="0,8,0,0">
                <Button x:Name="RemoveAssignedPresetButton"
                        Grid.Column="0"
                        Content="Remove"
                        automation:AutomationProperties.Name="Remove assigned preset"
                        Command="{Binding Morphs.RemoveSelectedPresetFromTargetCommand}" />
                <Button x:Name="ClearAssignedPresetsButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Clear"
                        automation:AutomationProperties.Name="Clear assigned presets"
                        Command="{Binding Morphs.ClearTargetPresetsCommand}" />
              </Grid>
            </Grid>
          </Border>

          <TextBlock Grid.Column="2"
                     Grid.Row="1"
                     Padding="12,4"
                     Text="{Binding Morphs.StatusMessage}"
                     TextWrapping="Wrap" />

          <Border Grid.Column="2"
                  Grid.Row="2"
                  Padding="12,4,12,4">
            <Grid RowDefinitions="Auto,*">
              <Grid Grid.Row="0"
                    ColumnDefinitions="Auto,Auto,*"
                    Margin="0,0,0,8">
                <Button x:Name="GenerateMorphsButton"
                        Grid.Column="0"
                        Content="Generate Morphs"
                        automation:AutomationProperties.Name="Generate morphs"
                        Command="{Binding Morphs.GenerateMorphsCommand}" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Copy"
                        automation:AutomationProperties.Name="Copy generated morphs"
                        Command="{Binding Morphs.CopyGeneratedMorphsCommand}" />
              </Grid>
              <TextBox Grid.Row="1"
                       x:Name="GeneratedMorphsTextBox"
                       automation:AutomationProperties.Name="Generated morphs"
                       Text="{Binding Morphs.GeneratedMorphsText}"
                       AcceptsReturn="True"
                       IsReadOnly="True"
                       TextWrapping="NoWrap"
                       FontFamily="Consolas"
                       FontSize="13" />
            </Grid>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Diagnostics">
        <Grid RowDefinitions="Auto,*"
              Margin="16">
          <Grid Grid.Row="0"
                ColumnDefinitions="*,Auto,Auto"
                Margin="0,0,0,16">
            <StackPanel Grid.Column="0"
                        Spacing="8">
              <TextBlock Text="Diagnostics"
                         FontSize="18"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding Diagnostics.SummaryText}"
                         TextWrapping="Wrap" />
              <TextBlock Text="{Binding Diagnostics.ProfileSummaryText}"
                         TextWrapping="Wrap"
                         Opacity="0.72" />
            </StackPanel>
            <Button x:Name="RunDiagnosticsButton"
                    Grid.Column="1"
                    Content="Run Diagnostics"
                    Margin="8,0,0,0"
                    automation:AutomationProperties.Name="Run Diagnostics"
                    Command="{Binding Diagnostics.RefreshDiagnosticsCommand}" />
            <Button x:Name="CopyDiagnosticsReportButton"
                    Grid.Column="2"
                    Content="Copy Report"
                    Margin="8,0,0,0"
                    automation:AutomationProperties.Name="Copy Report"
                    Command="{Binding Diagnostics.CopyReportCommand}" />
          </Grid>

          <Grid Grid.Row="1"
                ColumnDefinitions="*,4,2*"
                RowDefinitions="*,4,*">
            <Border Grid.Column="0"
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    Padding="16"
                    Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
              <Grid RowDefinitions="Auto,Auto,Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Summary"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,8,0,16">
                  <TextBlock Text="Blocker" />
                  <TextBlock Text="{Binding Diagnostics.BlockerCount}" />
                  <TextBlock Text="Caution" Margin="16,0,0,0" />
                  <TextBlock Text="{Binding Diagnostics.CautionCount}" />
                  <TextBlock Text="Info" Margin="16,0,0,0" />
                  <TextBlock Text="{Binding Diagnostics.InfoCount}" />
                </StackPanel>
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding Diagnostics.Areas}"
                              Margin="0,0,0,16">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="sys:String">
                      <TextBlock Text="{Binding .}"
                                 Margin="0,0,0,4" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ListBox x:Name="DiagnosticsFindingsListBox"
                         Grid.Row="3"
                         Focusable="True"
                         automation:AutomationProperties.Name="Diagnostics findings"
                         ItemsSource="{Binding Diagnostics.Findings}"
                         SelectedItem="{Binding Diagnostics.SelectedFinding}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:DiagnosticFindingViewModel">
                      <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                              BorderThickness="0,0,0,1"
                              Padding="0,8">
                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="Auto,*">
                          <TextBlock Grid.Row="0"
                                     Grid.Column="0"
                                     Text="{Binding SeverityLabel}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Margin="0,0,8,0" />
                          <TextBlock Grid.Row="0"
                                     Grid.Column="1"
                                     Text="{Binding Title}"
                                     TextWrapping="Wrap" />
                          <TextBlock Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding Area}"
                                     FontSize="12"
                                     Opacity="0.72" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Grid.Row="0"
                          Grid.RowSpan="3"
                          ResizeDirection="Columns" />

            <Grid Grid.Column="2"
                  Grid.Row="0"
                  RowDefinitions="Auto,*,Auto,*">
              <TextBlock Grid.Row="0"
                         Text="Selected Detail"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Margin="16,0,0,8" />
              <Border Grid.Row="1"
                      Margin="16,0,0,0"
                      Padding="16"
                      Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                      BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                      BorderThickness="1">
                <Grid RowDefinitions="Auto,*,Auto">
                  <TextBlock Grid.Row="0"
                             Text="No diagnostics yet"
                             FontSize="18"
                             FontWeight="SemiBold"
                             IsVisible="{Binding !Diagnostics.Findings.Count}" />
                  <TextBlock Grid.Row="1"
                             Text="{Binding Diagnostics.SelectedDetailText}"
                             TextWrapping="Wrap" />
                  <TextBlock Grid.Row="2"
                             Text="{Binding Diagnostics.StatusMessage}"
                             TextWrapping="Wrap"
                             Margin="0,16,0,0" />
                </Grid>
              </Border>

              <TextBlock Grid.Row="2"
                         Text="Profile Slider Drilldown"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Margin="16,16,0,8" />
              <ListBox Grid.Row="3"
                       Margin="16,0,0,0"
                       MaxHeight="160"
                       automation:AutomationProperties.Name="Profile slider diagnostics"
                       ItemsSource="{Binding Diagnostics.ProfileSliderDiagnostics}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="diag:ProfileSliderDiagnostic">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          Margin="0,4">
                      <TextBlock Grid.Column="0" Text="{Binding Name}" />
                      <TextBlock Grid.Column="1" Text="{Binding PresetName}" Margin="8,0,0,0" />
                      <TextBlock Grid.Column="2" Text="{Binding IsKnown}" Margin="8,0,0,0" />
                      <TextBlock Grid.Column="3" Text="{Binding IsInjectedDefault}" Margin="8,0,0,0" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>

            <GridSplitter Grid.Column="2"
                          Grid.Row="1"
                          ResizeDirection="Rows" />

            <Grid Grid.Column="2"
                  Grid.Row="2"
                  RowDefinitions="Auto,*,Auto,*"
                  Margin="16,16,0,0">
              <Grid Grid.Row="0"
                    ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0"
                            Spacing="4">
                  <TextBlock Text="Import and Export Previews"
                             FontSize="16"
                             FontWeight="SemiBold" />
                  <TextBlock Text="{Binding Morphs.NpcImportPreviewSummary}"
                             TextWrapping="Wrap" />
                </StackPanel>
                <Button x:Name="PreviewNpcImportButton"
                        Grid.Column="1"
                        Content="Preview NPC Import"
                        Margin="8,0,0,0"
                        automation:AutomationProperties.Name="Preview NPC Import"
                        Command="{Binding Morphs.PreviewNpcImportCommand}" />
                <Button x:Name="ImportPreviewedNpcsButton"
                        Grid.Column="2"
                        Content="Import Previewed NPCs"
                        Margin="8,0,0,0"
                        automation:AutomationProperties.Name="Import Previewed NPCs"
                        Command="{Binding Morphs.ImportPreviewedNpcsCommand}" />
              </Grid>

              <ListBox Grid.Row="1"
                       Margin="0,8,0,16"
                       automation:AutomationProperties.Name="NPC import preview rows"
                       ItemsSource="{Binding Morphs.NpcImportPreviewRows}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="workflow:NpcImportPreviewViewModel">
                    <Grid ColumnDefinitions="Auto,*,*,*,*"
                          Margin="0,4">
                      <TextBlock Grid.Column="0" Text="{Binding RowKind}" FontWeight="SemiBold" />
                      <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="8,0,0,0" />
                      <TextBlock Grid.Column="2" Text="{Binding Mod}" Margin="8,0,0,0" />
                      <TextBlock Grid.Column="3" Text="{Binding EditorId}" Margin="8,0,0,0" />
                      <TextBlock Grid.Column="4" Text="{Binding Detail}" Margin="8,0,0,0" TextWrapping="Wrap" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Grid Grid.Row="2"
                    ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0"
                             Spacing="4">
                  <TextBlock Text="{Binding ExportPreviewSummary}"
                             TextWrapping="Wrap" />
                  <Border Padding="8"
                          Margin="0,8,0,0"
                          Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                          BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                          BorderThickness="1"
                          automation:AutomationProperties.Name="Portable bundle preview">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="*,Auto,Auto,Auto">
                      <StackPanel Grid.Row="0"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="4"
                                  Spacing="4">
                        <TextBlock Text="Portable bundle preview"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Bundle reports use relative paths and source filenames only."
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Referenced custom profiles only"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Target files already exist. Enable overwrite to replace them."
                                   TextWrapping="Wrap" />
                      </StackPanel>
                      <ComboBox Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,8,8,0"
                                automation:AutomationProperties.Name="Bundle output intent"
                                ItemsSource="{Binding BundleOutputIntents}"
                                SelectedItem="{Binding BundleOutputIntent}" />
                      <CheckBox Grid.Row="1"
                                Grid.Column="1"
                                Margin="8,8,0,0"
                                Content="Overwrite existing zip"
                                automation:AutomationProperties.Name="Allow portable bundle overwrite"
                                IsChecked="{Binding BundleOverwriteAllowed}" />
                      <Button Grid.Row="1"
                              Grid.Column="2"
                              Margin="8,8,0,0"
                              Content="Preview Bundle"
                              automation:AutomationProperties.Name="Preview Portable Bundle"
                              Command="{Binding PreviewPortableBundleCommand}" />
                      <Button Grid.Row="1"
                              Grid.Column="3"
                              Margin="8,8,0,0"
                              Content="Create Portable Bundle"
                              automation:AutomationProperties.Name="Create Portable Bundle"
                              Command="{Binding CreatePortableBundleCommand}" />
                      <TextBlock Grid.Row="2"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="4"
                                 Margin="0,8,0,0"
                                 Text="{Binding BundlePreviewSummary}"
                                 TextWrapping="Wrap" />
                      <TextBlock Grid.Row="3"
                                 Grid.Column="0"
                                 Grid.ColumnSpan="4"
                                 Margin="0,8,0,0"
                                 Text="No absolute paths in manifest/report"
                                 TextWrapping="Wrap" />
                      <ItemsControl Grid.Row="4"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="4"
                                    Margin="0,8,0,0"
                                    ItemsSource="{Binding BundlePreviewEntries}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="sys:String">
                            <TextBlock Text="{Binding .}"
                                       FontFamily="Consolas"
                                       FontSize="12" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </Border>
                  <TextBlock Text="File operation incomplete"
                              FontWeight="SemiBold"
                              IsVisible="{Binding HasFileOperationLedger}" />
                </StackPanel>
                <Button x:Name="PreviewExportButton"
                        Grid.Column="1"
                        Content="Preview Export"
                        Margin="8,0,0,0"
                        automation:AutomationProperties.Name="Preview Export"
                        Command="{Binding PreviewBodyGenExportCommand}" />
                <Button x:Name="PreviewBosJsonExportButton"
                        Grid.Column="2"
                        Content="Preview BoS JSON"
                        Margin="8,0,0,0"
                        automation:AutomationProperties.Name="Preview BoS JSON export"
                        Command="{Binding PreviewBosJsonExportCommand}" />
              </Grid>

              <Grid Grid.Row="3"
                    ColumnDefinitions="*,*"
                    Margin="0,8,0,0">
                <ListBox Grid.Column="0"
                         automation:AutomationProperties.Name="Export preview files"
                         ItemsSource="{Binding ExportPreviewFiles}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="workflow:ExportPreviewViewModel">
                      <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                              BorderThickness="0,0,0,1"
                              Padding="0,8">
                        <Grid RowDefinitions="Auto,Auto,Auto">
                          <TextBlock Grid.Row="0" Text="{Binding TargetPath}" TextWrapping="Wrap" />
                          <TextBlock Grid.Row="1" Text="{Binding EffectLabel}" FontWeight="SemiBold" />
                          <ItemsControl Grid.Row="2" ItemsSource="{Binding SnippetLines}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="sys:String">
                                <TextBlock Text="{Binding .}" FontFamily="Consolas" FontSize="14" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <ListBox Grid.Column="1"
                         Margin="16,0,0,0"
                         automation:AutomationProperties.Name="File operation ledger rows"
                         ItemsSource="{Binding LastFileOperationLedger}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="workflow:FileOperationLedgerViewModel">
                      <Grid RowDefinitions="Auto,Auto"
                            Margin="0,4">
                        <TextBlock Grid.Row="0" Text="{Binding OutcomeLabel}" FontWeight="SemiBold" />
                        <TextBlock Grid.Row="1" Text="{Binding Path}" TextWrapping="Wrap" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Grid>
          </Grid>
        </Grid>
      </TabItem>

      <TabItem Header="Profiles"
               DataContext="{Binding Profiles}">
        <Grid x:DataType="vm:ProfileManagerViewModel"
              ColumnDefinitions="280,4,*"
              Margin="16">
          <Border Grid.Column="0"
                  Padding="16"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,*">
              <StackPanel Grid.Row="0"
                          Spacing="8">
                <TextBlock Text="Profile Manager"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBox x:Name="ProfileManagerSearchBox"
                         automation:AutomationProperties.Name="Search profiles"
                         Text="{Binding SearchText}"
                         PlaceholderText="Search profiles" />
                <Grid ColumnDefinitions="*,*">
                  <Button x:Name="ImportProfileButton"
                          Grid.Column="0"
                          Content="Import Profile"
                          automation:AutomationProperties.Name="Import Profile"
                          Command="{Binding ImportProfileCommand}" />
                  <Button x:Name="CreateBlankProfileButton"
                          Grid.Column="1"
                          Margin="8,0,0,0"
                          Content="Create Blank Profile"
                          automation:AutomationProperties.Name="Create Blank Profile"
                          Command="{Binding CreateBlankProfileCommand}" />
                </Grid>
              </StackPanel>

              <TextBlock Grid.Row="1"
                         Margin="0,16,0,8"
                         Text="Profile sources"
                         FontSize="16"
                         FontWeight="SemiBold" />

              <ScrollViewer Grid.Row="2"
                            VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                  <StackPanel Spacing="8">
                    <TextBlock Text="Bundled"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="BundledProfilesList"
                             automation:AutomationProperties.Name="Bundled profile rows"
                             ItemsSource="{Binding BundledProfiles}"
                             SelectedItem="{Binding SelectedProfile, Mode=OneWayToSource}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProfileManagerEntryViewModel">
                          <Border Padding="8"
                                  Margin="0,0,0,4"
                                  automation:AutomationProperties.Name="{Binding Name, StringFormat='Select bundled profile {0}'}"
                                  BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                  BorderThickness="0,0,0,1">
                            <Grid RowDefinitions="Auto,Auto">
                              <TextBlock Grid.Row="0" Text="{Binding Name}" />
                              <TextBlock Grid.Row="1"
                                         Text="{Binding SourceLabel}"
                                         FontSize="12" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <StackPanel Spacing="8">
                    <TextBlock Text="Custom"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="CustomProfilesList"
                             automation:AutomationProperties.Name="Custom profile rows"
                             ItemsSource="{Binding CustomProfiles}"
                             SelectedItem="{Binding SelectedProfile, Mode=OneWayToSource}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProfileManagerEntryViewModel">
                          <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                  BorderThickness="0,0,0,1"
                                  automation:AutomationProperties.Name="{Binding Name, StringFormat='Select custom profile {0}'}"
                                  Padding="0,8">
                            <Grid RowDefinitions="Auto,Auto">
                              <TextBlock Grid.Row="0" Text="{Binding Name}" />
                              <TextBlock Grid.Row="1" Text="{Binding SourceLabel}" FontSize="12" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <StackPanel Spacing="8">
                    <TextBlock Text="Embedded in project"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="EmbeddedProjectProfilesList"
                             automation:AutomationProperties.Name="Embedded project profile rows"
                             ItemsSource="{Binding EmbeddedProjectProfiles}"
                             SelectedItem="{Binding SelectedProfile, Mode=OneWayToSource}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProfileManagerEntryViewModel">
                          <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                  BorderThickness="0,0,0,1"
                                  automation:AutomationProperties.Name="{Binding Name, StringFormat='Select embedded project profile {0}'}"
                                  Padding="0,8">
                            <Grid RowDefinitions="Auto,Auto">
                              <TextBlock Grid.Row="0" Text="{Binding Name}" />
                              <TextBlock Grid.Row="1" Text="{Binding SourceLabel}" FontSize="12" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <StackPanel Spacing="8">
                    <TextBlock Text="Missing references"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="MissingProfileReferencesList"
                             automation:AutomationProperties.Name="Missing profile reference rows"
                             ItemsSource="{Binding MissingProfiles}"
                             SelectedItem="{Binding SelectedProfile, Mode=OneWayToSource}">
                      <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProfileManagerEntryViewModel">
                          <Border Padding="8"
                                  Background="{DynamicResource BS2BGInfoBackgroundBrush}"
                                  automation:AutomationProperties.Name="{Binding Name, StringFormat='Select missing profile reference {0}'}"
                                  BorderBrush="{DynamicResource BS2BGInfoBorderBrush}"
                                  BorderThickness="1">
                            <Grid RowDefinitions="Auto,Auto">
                              <TextBlock Grid.Row="0" Text="{Binding Name}" />
                              <TextBlock Grid.Row="1" Text="{Binding SourceLabel}" FontSize="12" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ListBox.ItemTemplate>
                    </ListBox>
                  </StackPanel>

                  <StackPanel Spacing="8">
                    <TextBlock Text="Rejected profile files"
                               FontWeight="SemiBold" />
                    <ItemsControl x:Name="RejectedProfileFilesList"
                                  ItemsSource="{Binding RejectedProfileFiles}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ProfileValidationDiagnostic">
                          <Grid RowDefinitions="Auto,Auto"
                                Margin="0,0,0,8">
                            <TextBlock Grid.Row="0" Text="{Binding Severity}" FontSize="12" />
                            <TextBlock Grid.Row="1" Text="{Binding Message}" TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>
              </ScrollViewer>
            </Grid>
          </Border>

          <GridSplitter Grid.Column="1"
                        ResizeDirection="Columns" />

          <Border Grid.Column="2"
                  Margin="16,0,0,0"
                  Padding="16"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                  BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,*">
              <Grid Grid.Row="0"
                    ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">
                <StackPanel Grid.Column="0"
                            Spacing="4">
                  <TextBlock Text="Profile Manager"
                             FontSize="18"
                             FontWeight="SemiBold" />
                  <TextBlock Text="Bundled — read-only / Custom — editable / Embedded in project / Missing — using fallback"
                             TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Copy as Custom Profile"
                        automation:AutomationProperties.Name="Copy as Custom Profile"
                        Command="{Binding CopyBundledProfileCommand}" />
                <Button Grid.Column="2"
                        Margin="8,0,0,0"
                        Content="Export Profile JSON"
                        automation:AutomationProperties.Name="Export Profile JSON"
                        Command="{Binding ExportProfileCommand}" />
                <Button Grid.Column="3"
                        Margin="8,0,0,0"
                        Content="Delete Custom Profile"
                        automation:AutomationProperties.Name="Delete Custom Profile"
                        Command="{Binding DeleteCustomProfileCommand}" />
                <Button Grid.Column="4"
                        Margin="8,0,0,0"
                        Content="Validate Profile"
                        automation:AutomationProperties.Name="Validate Profile"
                        Command="{Binding ValidateProfileCommand}" />
                <Button Grid.Column="5"
                        Margin="8,0,0,0"
                        Content="Save Profile"
                        automation:AutomationProperties.Name="Save Profile"
                        Command="{Binding SaveProfileCommand}" />
              </Grid>

              <TextBlock Grid.Row="1"
                         Margin="0,16,0,16"
                         Text="{Binding StatusMessage}"
                         TextWrapping="Wrap" />

              <ContentControl Grid.Row="2"
                              Content="{Binding Editor}">
                <ContentControl.ContentTemplate>
                  <DataTemplate x:DataType="vm:ProfileEditorViewModel">
                    <Grid x:Name="ProfileEditorRoot"
                          x:DataType="vm:ProfileEditorViewModel"
                          RowDefinitions="Auto,Auto,Auto,Auto,*">
                      <Grid Grid.Row="0"
                            ColumnDefinitions="*,*"
                            Margin="0,0,0,16">
                        <TextBox Grid.Column="0"
                                 automation:AutomationProperties.Name="Profile display name"
                                 Text="{Binding Name}"
                                 PlaceholderText="Profile display name" />
                        <TextBox Grid.Column="1"
                                 Margin="8,0,0,0"
                                 automation:AutomationProperties.Name="Profile game metadata"
                                 Text="{Binding Game}"
                                 PlaceholderText="Game metadata" />
                      </Grid>
                      <TextBlock Grid.Row="1"
                                 Text="Blank profiles are allowed. Add defaults, multipliers, and inverted sliders when you are ready."
                                 TextWrapping="Wrap"
                                 Margin="0,0,0,16" />
                      <TextBox Grid.Row="2"
                               automation:AutomationProperties.Name="Filter profile sliders"
                               Text="{Binding SearchText}"
                               PlaceholderText="Filter sliders"
                               Margin="0,0,0,16" />
                      <ItemsControl Grid.Row="3"
                                    ItemsSource="{Binding ValidationRows}"
                                    Margin="0,0,0,16">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:ProfileEditorStatusRowViewModel">
                            <Grid ColumnDefinitions="Auto,*"
                                  Margin="0,0,0,8">
                              <TextBlock Grid.Column="0" Text="{Binding Severity}" FontSize="12" FontWeight="SemiBold" />
                              <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" Margin="8,0,0,0" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <ScrollViewer Grid.Row="4"
                                    VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="16">
                          <TextBlock Text="Metadata" FontSize="16" FontWeight="SemiBold" />
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Defaults" FontSize="16" FontWeight="SemiBold" />
                            <Button Grid.Column="1"
                                    Content="Add default slider"
                                    automation:AutomationProperties.Name="Add default slider"
                                    Command="{Binding AddDefaultCommand}" />
                          </Grid>
                          <ItemsControl ItemsSource="{Binding VisibleDefaultRows}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:ProfileDefaultRowViewModel">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,8">
                                  <TextBox Grid.Column="0"
                                           Text="{Binding Slider, UpdateSourceTrigger=PropertyChanged}"
                                           automation:AutomationProperties.Name="Default slider name" />
                                  <TextBox Grid.Column="1" Width="64" Text="{Binding ValueSmall, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Default small value" />
                                  <TextBox Grid.Column="2" Width="64" Margin="8,0,0,0" Text="{Binding ValueBig, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Default big value" />
                                  <Button Grid.Column="3"
                                          Margin="8,0,0,0"
                                          Content="Remove"
                                          automation:AutomationProperties.Name="Remove default slider"
                                          Command="{Binding #ProfileEditorRoot.DataContext.RemoveDefaultCommand}"
                                          CommandParameter="{Binding .}" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Multipliers" FontSize="16" FontWeight="SemiBold" />
                            <Button Grid.Column="1"
                                    Content="Add multiplier slider"
                                    automation:AutomationProperties.Name="Add multiplier slider"
                                    Command="{Binding AddMultiplierCommand}" />
                          </Grid>
                          <ItemsControl ItemsSource="{Binding VisibleMultiplierRows}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:ProfileMultiplierRowViewModel">
                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
                                  <TextBox Grid.Column="0"
                                           Text="{Binding Slider, UpdateSourceTrigger=PropertyChanged}"
                                           automation:AutomationProperties.Name="Multiplier slider name" />
                                  <TextBox Grid.Column="1" Width="64" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="Multiplier value" />
                                  <Button Grid.Column="2"
                                          Margin="8,0,0,0"
                                          Content="Remove"
                                          automation:AutomationProperties.Name="Remove multiplier slider"
                                          Command="{Binding #ProfileEditorRoot.DataContext.RemoveMultiplierCommand}"
                                          CommandParameter="{Binding .}" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Inverted Sliders" FontSize="16" FontWeight="SemiBold" />
                            <Button Grid.Column="1"
                                    Content="Add inverted slider"
                                    automation:AutomationProperties.Name="Add inverted slider"
                                    Command="{Binding AddInvertedCommand}" />
                          </Grid>
                          <ItemsControl ItemsSource="{Binding VisibleInvertedRows}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:ProfileInvertedRowViewModel">
                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,8">
                                  <TextBox Grid.Column="0"
                                           Text="{Binding Slider, UpdateSourceTrigger=PropertyChanged}"
                                           automation:AutomationProperties.Name="Inverted slider name" />
                                  <CheckBox Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Content="Included"
                                            IsChecked="{Binding IsInverted}"
                                            automation:AutomationProperties.Name="Inverted slider" />
                                  <Button Grid.Column="2"
                                          Margin="8,0,0,0"
                                          Content="Remove"
                                          automation:AutomationProperties.Name="Remove inverted slider"
                                          Command="{Binding #ProfileEditorRoot.DataContext.RemoveInvertedCommand}"
                                          CommandParameter="{Binding .}" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                          <TextBlock Text="Validation" FontSize="16" FontWeight="SemiBold" />
                        </StackPanel>
                      </ScrollViewer>
                    </Grid>
                  </DataTemplate>
                </ContentControl.ContentTemplate>
              </ContentControl>
            </Grid>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
