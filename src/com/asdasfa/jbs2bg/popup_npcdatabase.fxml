<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="mainPane" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8.0.152" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.asdasfa.jbs2bg.PopupNpcDatabaseController">
   <children>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="5.0" VBox.vgrow="ALWAYS">
         <VBox.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </VBox.margin>
         <children>
            <HBox prefHeight="32.0" prefWidth="200.0">
               <children>
                  <HBox prefHeight="32.0" prefWidth="335.0" spacing="15.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Button alignment="CENTER" maxHeight="1.7976931348623157E308" mnemonicParsing="false" onAction="#addNpcsFromFile" prefHeight="32.0" prefWidth="200.0" text="Add NPCs from File" />
                        <Label fx:id="lblNpcCounter" focusTraversable="false" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="32.0" prefWidth="100.0" text="(999)" HBox.hgrow="ALWAYS">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
                  <HBox alignment="TOP_RIGHT" prefHeight="100.0" prefWidth="200.0" spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <CheckBox fx:id="cbAssignRandom" mnemonicParsing="false" prefHeight="32.0" prefWidth="125.0" text="Assign Random" HBox.hgrow="ALWAYS" />
                        <Button alignment="CENTER" maxHeight="1.7976931348623157E308" mnemonicParsing="false" onAction="#showPopupImageView" prefHeight="32.0" prefWidth="110.0" text="View Image" />
                     </children>
                  </HBox>
               </children>
            </HBox>
            <TableView fx:id="tvNpcDatabase" prefHeight="270.0" prefWidth="580.0" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="tcName" editable="false" minWidth="50.0" prefWidth="125.0" text="Name" />
                  <TableColumn fx:id="tcMaster" editable="false" prefWidth="120.0" text="Master" />
                  <TableColumn fx:id="tcRace" editable="false" prefWidth="125.0" text="Race" />
                  <TableColumn fx:id="tcEditorId" editable="false" prefWidth="125.0" text="EditorID" />
                  <TableColumn fx:id="tcFormId" editable="false" prefWidth="75.0" text="FormID" />
               </columns>
            </TableView>
            <HBox alignment="BOTTOM_LEFT" prefHeight="32.0" prefWidth="200.0">
               <children>
                  <HBox alignment="BOTTOM_LEFT" prefHeight="32.0" prefWidth="390.0" spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Button alignment="CENTER" maxHeight="1.7976931348623157E308" mnemonicParsing="false" onAction="#addNpcToMorph" prefHeight="32.0" prefWidth="110.0" text="&lt;= Add" />
                        <Button alignment="CENTER" layoutX="10.0" layoutY="10.0" maxHeight="1.7976931348623157E308" mnemonicParsing="false" onAction="#showConfirmAddAllNpcs" prefHeight="32.0" prefWidth="110.0" text="Add All" />
                        <Button alignment="CENTER" maxHeight="1.7976931348623157E308" mnemonicParsing="false" onAction="#hide" prefHeight="32.0" prefWidth="110.0" text="Back" />
                     </children>
                  </HBox>
                  <HBox alignment="BOTTOM_RIGHT" prefHeight="100.0" prefWidth="200.0" spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Button alignment="CENTER" maxHeight="1.7976931348623157E308" mnemonicParsing="false" onAction="#showConfirmClearNpcDatabase" prefHeight="32.0" prefWidth="110.0" text="Clear" />
                     </children>
                  </HBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>
