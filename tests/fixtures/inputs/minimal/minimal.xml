<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal hand-authored BodySlide preset fixture for BS2BG unit tests.
  Every SetSlider here is chosen to exercise a specific code path in
  SliderPreset.toLine / SetSlider.toText / SliderPreset.toBosJson:

  - Preset 1 "AllCases"   : one inverted slider at both-100 (must be EXCLUDED
                            when omitRedundantSliders=true), one non-inverted
                            at both-0 (EXCLUDED), a regular big/small pair,
                            and a slider with small-only value (big falls
                            back to profile default).
  - Preset 2 "Negatives"  : negative small and big values.
  - Preset 3 "MissingDef" : a preset with no defaults-category sliders at
                            all, forcing the missing-default injection path
                            to populate every entry in settings.json Defaults.

  Slider names deliberately match Skyrim-CBBE profile
  (settings.json Defaults + Inverted) so the math paths are fully exercised.
-->
<SliderPresets>
    <Preset name="AllCases" set="Test">
        <Group name="Test"/>
        <SetSlider name="Breasts" size="big" value="100"/>
        <SetSlider name="Breasts" size="small" value="100"/>
        <SetSlider name="Butt" size="big" value="0"/>
        <SetSlider name="Butt" size="small" value="0"/>
        <SetSlider name="Waist" size="big" value="60"/>
        <SetSlider name="Waist" size="small" value="40"/>
        <SetSlider name="Arms" size="small" value="25"/>
    </Preset>
    <Preset name="Negatives" set="Test">
        <Group name="Test"/>
        <SetSlider name="Breasts" size="big" value="-25"/>
        <SetSlider name="Breasts" size="small" value="-50"/>
        <SetSlider name="Legs" size="big" value="80"/>
    </Preset>
    <Preset name="MissingDef" set="Test">
        <Group name="Test"/>
        <SetSlider name="NipBGone" size="big" value="100"/>
    </Preset>
</SliderPresets>
